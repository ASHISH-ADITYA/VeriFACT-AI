# VeriFactAI Environment Configuration
# Copy this file to .env and fill in your API keys

# LLM Provider: "ollama" (free local), "anthropic", or "openai"
LLM_PROVIDER=ollama

# Ollama (free local inference)
# Install: https://ollama.com
# Run: ollama pull llama3.1:8b
# Ensure local server is running: ollama serve
OLLAMA_BASE_URL=http://localhost:11434

# API Keys (at least one required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Model Configuration
LLM_MODEL=llama3.1:8b
LLM_TEMPERATURE=0.1

# Paths (defaults work out of the box)
FAISS_INDEX_PATH=data/index/knowledge.index
METADATA_PATH=data/metadata/chunks.jsonl

# Embedding & NLI Models (downloaded automatically from HuggingFace)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
NLI_MODEL=cross-encoder/nli-deberta-v3-base
